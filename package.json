{
  "name": "shell-gems",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "npm-run-all --parallel build:angular:watch build:main:watch wait:electron",
    "build:angular": "cd renderer && npm run build",
    "build:angular:watch": "cd renderer && npm run watch",
    "build:main": "tsc",
    "build:main:watch": "tsc -w",
    "wait:electron": "wait-on renderer/dist/renderer/browser/index.html && electron .",
    "build:portable": "npm run build:angular && npm run build:main && electron-builder"
  },
  "keywords": [],
  "author": "Shell-Gems",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.shell.gems",
    "productName": "Shell-Gems",
    "directories": {
      "output": "dist/win-unpacked"
    },
    "files": [
      "dist/main/**/*",
      "renderer/dist/renderer/browser/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "plugins",
        "to": "plugins",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "dir"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "electron-edge-js": "^40.0.1"
  }
}
